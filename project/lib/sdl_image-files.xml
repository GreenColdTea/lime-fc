			<compilerflag value="-I${NATIVE_TOOLKIT_PATH}/sdl/include" />

		</section>

		<compilerflag value="-I${NATIVE_TOOLKIT_PATH}/sdl_image/include" />
		<compilerflag value="-I${NATIVE_TOOLKIT_PATH}/sdl_image/src" />

