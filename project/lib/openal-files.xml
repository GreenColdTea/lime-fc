<xml>

    <section if="android LIME_OPENALSOFT">
        <error value="NDK version 20 or higher is required." unless="NDKV20+" />
    </section>

    <files id="native-toolkit-openal">

        <section>

            <section if="linux">

                <compilerflag value="-I/usr/include/pipewire-0.3" />
                <compilerflag value="-I/usr/include/spa-0.2" />
                <compilerflag value="-I/usr/include/dbus-1.0" />

                <section>

                    <compilerflag value="-I/usr/lib/dbus-1.0/include" />
                    <compilerflag value="-I/usr/lib/aarch64-linux-gnu/dbus-1.0/include" if="HXCPP_ARM64" />
                    <compilerflag value="-I/usr/lib/x86_64-linux-gnu/dbus-1.0/include" if="HXCPP_M64" unless="HXCPP_ARM64" />
                    <compilerflag value="-I/usr/lib/i386-linux-gnu/dbus-1.0/include" if="HXCPP_M32" />

                </section>

            </section>

            <compilerflag value="-I${NATIVE_TOOLKIT_PATH}/openal/fmt-11.2.0/include" />

            <compilerflag value="-I${NATIVE_TOOLKIT_PATH}/openal/gsl/include" />

            <compilerflag value="-I${NATIVE_TOOLKIT_PATH}/sdl/include" if="NATIVE_TOOLKIT_HAVE_SDL" />

        </section>

        <compilerflag value="-I${NATIVE_TOOLKIT_PATH}/openal" />
        <compilerflag value="-I${NATIVE_TOOLKIT_PATH}/openal/alc" />
        <compilerflag value="-I${NATIVE_TOOLKIT_PATH}/openal/common" />
        <compilerflag value="-I${NATIVE_TOOLKIT_PATH}/openal/core" />

        <compilerflag value="-I${NATIVE_TOOLKIT_PATH}/custom/openal/include" />
        <compilerflag value="-I${NATIVE_TOOLKIT_PATH}/openal/include" />

        <section>

            <compilerflag value="-DAL_ALEXT_PROTOTYPES" />

            <compilerflag value="-DAL_LIBTYPE_STATIC" />

            <compilerflag value="-DNATIVE_TOOLKIT_HAVE_SDL" if="NATIVE_TOOLKIT_HAVE_SDL" />

        </section>

        <section>

            <section if="isMsvc">

                <compilerflag value="-DNOMINMAX" />

                <compilerflag value="/utf-8" />

                <compilerflag value="/wd4267" />

            </section>

            <section unless="isMsvc">

                <compilerflag value="-Wno-switch" if="android" />

                <section if="linux || mingw">

                    <compilerflag value="-Wno-stringop-overflow" />
                    <compilerflag value="-Wno-interference-size" />

                </section>

                <compilerflag value="-Wno-deprecated-anon-enum-enum-conversion" if="apple" />

            </section>

        </section>

